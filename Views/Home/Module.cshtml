@model ModuleViewModel
@{ ViewData["Title"] = $"{Model.ModuleName.ToUpper()} MACHINE CENTER"; }

<style>
    .machine-filters { display:flex; flex-wrap:wrap; gap:6px; padding:10px 16px; border-bottom:1px solid var(--border); background:var(--surface); }
    .mf-btn { padding:3px 10px; font-size:.7rem; font-family:var(--font-mono); border:1px solid var(--border); border-radius:var(--radius); background:var(--surface2); color:var(--text2); cursor:pointer; white-space:nowrap; transition:background .15s,color .15s,border-color .15s; }
    .mf-btn:hover { background:var(--surface3,#2a2a2a); color:var(--text); }
    .mf-btn.active { background:var(--orange,#F77F00); color:#fff; border-color:var(--orange,#F77F00); }
    @@media print {
        .sidebar, .topbar, .machine-filters, .table-header, .btn { display:none !important; }
        .table-wrap { box-shadow:none; border:none; }
        body { background:#fff; color:#000; }
        table { font-size:.75rem; }
        th, td { border:1px solid #ccc !important; padding:4px 6px !important; color:#000 !important; }
        .chip { border:1px solid #ccc; color:#000 !important; background:#eee !important; }
        .chip-green { background:#d4edda !important; color:#155724 !important; border-color:#c3e6cb !important; }
        .chip-red { background:#f8d7da !important; color:#721c24 !important; border-color:#f5c6cb !important; }
        .serial-cell { font-family:monospace; }
        th:nth-child(12), td:nth-child(12),
        th:nth-child(13), td:nth-child(13),
        th:nth-child(14), td:nth-child(14) { display:none !important; }
        .print-header { display:flex !important; align-items:center; gap:16px; margin-bottom:12px; padding-bottom:10px; border-bottom:2px solid #ccc; }
        .print-header img { height:56px; object-fit:contain; }
        .print-header-text { font-size:1rem; font-weight:700; color:#000; letter-spacing:.05em; }
        .print-header-sub { font-size:.75rem; color:#555; margin-top:2px; }
    }
</style>

<div class="table-wrap">
    <div class="print-header" style="display:none">
        <img src="/images/Susha Logo.png" alt="Susha India" />
        <div>
            <div class="print-header-text">SUSHA PRODUCTION TRACKER</div>
            <div class="print-header-sub">@Model.ModuleName.ToUpper() MACHINE CENTER — Printed @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
    </div>
    <div class="table-header">
        <div style="display:flex;align-items:center;gap:12px">
            <h2>@Model.ModuleName.ToUpper() JOBS</h2>
            <span class="count">@Model.Jobs.Count entries</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            @{ ViewBag.FilterAction = "Module"; ViewBag.FilterExtra = new Dictionary<string, string> { { "name", Model.ModuleName } }; }
            @await Html.PartialAsync("_FilterBar")
            @if (User.IsInRole("Manager") || User.IsInRole("Planner"))
            {
                <button class="btn btn-sm" onclick="window.print()" style="white-space:nowrap">Print</button>
            }
        </div>
    </div>

    <div class="machine-filters">
        <button class="mf-btn active" onclick="setFilter(this, 'all')">All</button>
        @for (int i = 1; i <= Model.MachineCount; i++)
        {
            <button class="mf-btn" onclick="setFilter(this, '@i')">@Model.ModuleName #@i</button>
        }
    </div>

    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>Serial</th><th>Customer</th><th>Model</th><th>Drawing No.</th><th>Item Code</th><th>Description</th><th>Total Qty</th><th>Step</th>
                    <th>@Model.ModuleName #</th><th>Done</th><th>Remaining</th><th>Record Qty</th><th>Status</th><th>Last Updated</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mj in Model.Jobs)
                {
                    var done = mj.FinishedQty ?? 0;
                    var remaining = mj.Qty - done;
                    var pct = mj.Qty > 0 ? (int)((double)done / mj.Qty * 100) : 0;
                    <tr data-machine="@(mj.MachineNumber ?? "")">
                        <td class="serial-cell">@mj.Serial</td>
                        <td>@mj.Customer</td>
                        <td>@mj.Model</td>
                        <td style="font-family:var(--font-mono);font-size:.75rem">@mj.Drawing</td>
                        <td style="font-family:var(--font-mono);font-size:.75rem">@(mj.ItemCode ?? "—")</td>
                        <td style="font-size:.75rem;color:var(--text2)">@mj.DrawingDescription</td>
                        <td>@mj.Qty</td>
                        <td>
                            <span class="chip @(mj.IsFinished ? "chip-green" : "chip-red")">Step @(mj.StepIndex + 1)</span>
                        </td>

                        <!-- Machine Number -->
                        <td>
                            @if (mj.IsFinished)
                            {
                                <span style="font-family:var(--font-mono);font-size:.75rem">@Model.ModuleName #@mj.MachineNumber</span>
                            }
                            else if (mj.ModuleEntryId.HasValue)
                            {
                                <form method="post" asp-action="SetMachine" style="display:inline-flex;align-items:center;gap:4px">
                                    <input type="hidden" name="moduleEntryId" value="@mj.ModuleEntryId" />
                                    <input type="hidden" name="moduleName" value="@Model.ModuleName" />
                                    <select name="machineNumber">
                                        <option value="">—</option>
                                        @for (int i = 1; i <= Model.MachineCount; i++)
                                        {
                                            <option value="@i" selected="@(mj.MachineNumber == i.ToString())">@Model.ModuleName #@i</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary" style="padding:2px 7px;font-size:.65rem">✓</button>
                                </form>
                            }
                        </td>

                        <!-- Done -->
                        <td style="font-family:var(--font-mono);font-weight:600;color:@(mj.IsFinished ? "var(--green)" : "var(--text)")">
                            @done
                            <span style="font-size:.65rem;color:var(--text3);font-weight:400"> / @mj.Qty</span>
                        </td>

                        <!-- Remaining -->
                        <td style="font-family:var(--font-mono);font-weight:600;color:@(remaining == 0 ? "var(--green)" : "var(--red)")">
                            @remaining
                        </td>

                        <!-- Record Qty -->
                        <td>
                            @if (mj.IsFinished)
                            {
                                <span class="chip chip-green">✓ Complete</span>
                            }
                            else
                            {
                                <form method="post" asp-action="RecordQty" style="display:inline-flex;align-items:center;gap:4px">
                                    <input type="hidden" name="JobId" value="@mj.JobId" />
                                    <input type="hidden" name="ModuleName" value="@Model.ModuleName" />
                                    <input type="hidden" name="StepIndex" value="@mj.StepIndex" />
                                    <input type="number" name="RecordQty" min="1" max="@mj.AvailableQty" placeholder="Qty"
                                           style="width:55px;padding:2px 4px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:var(--font-mono);font-size:.75rem;text-align:center" />
                                    <button type="submit" class="btn btn-sm btn-primary" style="padding:4px 10px;font-size:.65rem;white-space:nowrap">
                                        Record
                                    </button>
                                </form>
                            }
                        </td>

                        <!-- Status -->
                        <td>
                            @if (mj.IsFinished)
                            {
                                <span class="chip chip-green">DONE</span>
                            }
                            else if (done > 0)
                            {
                                <span class="chip chip-red">@pct%</span>
                            }
                            else
                            {
                                <span style="color:var(--text3);font-size:.75rem;font-family:var(--font-mono)">Not Started</span>
                            }
                        </td>

                        <!-- Last Updated -->
                        <td>
                            @if (!string.IsNullOrEmpty(mj.FinishedDate))
                            {
                                <span class="finished-date">@mj.FinishedDate</span>
                            }
                            else
                            {
                                <span class="not-finished">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function setFilter(btn, filter) {
        document.querySelectorAll('.mf-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('tbody tr').forEach(row => {
            if (filter === 'all') {
                row.style.display = '';
            } else {
                row.style.display = (row.dataset.machine === filter) ? '' : 'none';
            }
        });
    }
</script>
