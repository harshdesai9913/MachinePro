@model MasterDataViewModel
@{ ViewData["Title"] = "MASTER DATA"; }

@{
    var successMsg = TempData["Success"] as string;
}

@if (!string.IsNullOrEmpty(successMsg))
{
    <div style="background:var(--green-bg);border:1px solid var(--green-border);border-radius:var(--radius-lg);padding:14px 20px;margin-bottom:16px;color:var(--green);font-size:.85rem;font-weight:600;font-family:var(--font-mono)">
        ✓ @successMsg
    </div>
}

<!-- TWO INDEPENDENT SECTIONS -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;font-size:.82rem">

    <!-- ════════ LEFT: CUSTOMERS ════════ -->
    <div>
        <!-- Upload Customers CSV -->
        <div class="table-wrap" style="padding:14px;margin-bottom:12px">
            <h2 style="font-family:var(--font-mono);font-size:.75rem;color:var(--white);margin-bottom:6px;letter-spacing:1px">UPLOAD CUSTOMERS</h2>
            <p style="font-size:.65rem;color:var(--text3);margin-bottom:10px">
                Columns: <strong>Customer Name · City · State · Country</strong> — City, State, Country are optional (Country defaults to India)
            </p>
            <form method="post" asp-action="UploadCustomerCsv" enctype="multipart/form-data" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                <input type="file" name="csvFile" accept=".csv" required
                       style="padding:5px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-size:.7rem;flex:1;min-width:140px" />
                <button type="submit" class="btn btn-sm btn-primary">Upload</button>
            </form>
        </div>

        <!-- Add Customer Manually -->
        <div class="table-wrap" style="padding:14px;margin-bottom:12px">
            <h2 style="font-family:var(--font-mono);font-size:.75rem;color:var(--white);margin-bottom:10px;letter-spacing:1px">ADD CUSTOMER</h2>
            <form method="post" asp-action="AddCustomer">
                <div class="form-grid" style="grid-template-columns:1fr 1fr;margin-bottom:12px">
                    <div class="form-group">
                        <label>Customer Name</label>
                        <input name="CustomerName" placeholder="e.g. Hero MotoCorp" required />
                    </div>
                    <div class="form-group">
                        <label>Country</label>
                        <select name="Country">
                            <option value="India" selected>India</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>State</label>
                        <select name="State">
                            <option value="">— Select State —</option>
                            <option>Andhra Pradesh</option><option>Arunachal Pradesh</option><option>Assam</option>
                            <option>Bihar</option><option>Chhattisgarh</option><option>Goa</option>
                            <option>Gujarat</option><option>Haryana</option><option>Himachal Pradesh</option>
                            <option>Jharkhand</option><option>Karnataka</option><option>Kerala</option>
                            <option>Madhya Pradesh</option><option>Maharashtra</option><option>Manipur</option>
                            <option>Meghalaya</option><option>Mizoram</option><option>Nagaland</option>
                            <option>Odisha</option><option>Punjab</option><option>Rajasthan</option>
                            <option>Sikkim</option><option>Tamil Nadu</option><option>Telangana</option>
                            <option>Tripura</option><option>Uttar Pradesh</option><option>Uttarakhand</option>
                            <option>West Bengal</option>
                            <option>Andaman and Nicobar Islands</option><option>Chandigarh</option>
                            <option>Dadra and Nagar Haveli and Daman and Diu</option><option>Delhi</option>
                            <option>Jammu and Kashmir</option><option>Ladakh</option>
                            <option>Lakshadweep</option><option>Puducherry</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>City</label>
                        <input name="City" placeholder="e.g. Pune" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Add Customer</button>
            </form>
        </div>

        <!-- Customer List -->
        <div class="table-wrap">
            <div class="table-header">
                <h2>CUSTOMERS</h2>
                <span class="count">@Model.Customers.Count entries</span>
            </div>
            <div class="table-scroll" style="max-height:400px;overflow-y:auto">
                <table>
                    <thead><tr><th>Customer Name</th><th>City</th><th>State</th><th>Country</th><th style="width:80px">Action</th></tr></thead>
                    <tbody>
                        @foreach (var c in Model.Customers)
                        {
                            <tr>
                                <td>@c.CustomerName</td>
                                <td style="font-size:.72rem">@(c.City ?? "—")</td>
                                <td style="font-size:.72rem">@(c.State ?? "—")</td>
                                <td style="font-size:.72rem">@(c.Country)</td>
                                <td>
                                    <form method="post" asp-action="DeleteCustomer" style="display:inline">
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <button type="submit" onclick="return confirm('Delete @c.CustomerName?')"
                                                style="background:none;border:none;color:var(--red);cursor:pointer;font-size:.72rem;font-weight:700;font-family:var(--font-mono)">✕ Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ════════ RIGHT: MODELS ════════ -->
    <div>
        <!-- Upload Models CSV -->
        <div class="table-wrap" style="padding:14px;margin-bottom:12px">
            <h2 style="font-family:var(--font-mono);font-size:.75rem;color:var(--white);margin-bottom:6px;letter-spacing:1px">UPLOAD MODELS</h2>
            <p style="font-size:.65rem;color:var(--text3);margin-bottom:10px">
                CSV with one column: <strong>ModelName</strong>
            </p>
            <form method="post" asp-action="UploadModelCsv" enctype="multipart/form-data" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                <input type="file" name="csvFile" accept=".csv" required
                       style="padding:5px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-size:.7rem;flex:1;min-width:140px" />
                <button type="submit" class="btn btn-sm btn-primary">Upload</button>
            </form>
        </div>

        <!-- Add Model Manually -->
        <div class="table-wrap" style="padding:14px;margin-bottom:12px">
            <h2 style="font-family:var(--font-mono);font-size:.75rem;color:var(--white);margin-bottom:10px;letter-spacing:1px">ADD MODEL</h2>
            <form method="post" asp-action="AddModel" style="display:flex;gap:8px;align-items:end">
                <div class="form-group" style="flex:1">
                    <label>Model Name</label>
                    <input name="ModelName" placeholder="e.g. TM-600Z" required />
                </div>
                <button type="submit" class="btn btn-primary" style="margin-bottom:0">Add</button>
            </form>
        </div>

        <!-- Model List -->
        <div class="table-wrap">
            <div class="table-header">
                <h2>MODELS</h2>
                <span class="count">@Model.Models.Count entries</span>
            </div>
            <div class="table-scroll" style="max-height:400px;overflow-y:auto">
                <table>
                    <thead><tr><th>Model Name</th><th style="width:80px">Action</th></tr></thead>
                    <tbody>
                        @foreach (var m in Model.Models)
                        {
                            <tr>
                                <td>@m.ModelName</td>
                                <td>
                                    <form method="post" asp-action="DeleteModel" style="display:inline">
                                        <input type="hidden" name="id" value="@m.Id" />
                                        <button type="submit" onclick="return confirm('Delete @m.ModelName?')"
                                                style="background:none;border:none;color:var(--red);cursor:pointer;font-size:.72rem;font-weight:700;font-family:var(--font-mono)">✕ Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
