@model TrackerViewModel
@{ ViewData["Title"] = "PRODUCTION TRACKER"; }

@{
    var modules = new[] {
        ("VMC", 4), ("Milling", 3), ("Lathe", 4), ("Shaper", 1)
    };
}

<style>
    .machine-filters { display:flex; flex-wrap:wrap; gap:6px; padding:10px 16px; border-bottom:1px solid var(--border); background:var(--surface); }
    .mf-btn { padding:3px 10px; font-size:.7rem; font-family:var(--font-mono); border:1px solid var(--border); border-radius:var(--radius); background:var(--surface2); color:var(--text2); cursor:pointer; white-space:nowrap; transition:background .15s,color .15s,border-color .15s; }
    .mf-btn:hover { background:var(--surface3,#2a2a2a); color:var(--text); }
    .mf-btn.active { background:var(--orange,#F77F00); color:#fff; border-color:var(--orange,#F77F00); }
    .mf-sep { width:1px; background:var(--border); margin:0 2px; }
    @@media print {
        .sidebar, .topbar, .machine-filters, .table-header, .btn { display:none !important; }
        .table-wrap { box-shadow:none; border:none; }
        body { background:#fff; color:#000; }
        table { font-size:.75rem; }
        th, td { border:1px solid #ccc !important; padding:4px 6px !important; color:#000 !important; }
        .chip { border:1px solid #ccc; color:#000 !important; background:#eee !important; }
        .chip-green { background:#d4edda !important; color:#155724 !important; border-color:#c3e6cb !important; }
        .chip-red { background:#f8d7da !important; color:#721c24 !important; border-color:#f5c6cb !important; }
        .row-green td { background:#eafaf1 !important; }
        .serial-cell { font-family:monospace; }
    }
</style>

<div class="table-wrap">
    <div class="table-header">
        <div style="display:flex;align-items:center;gap:12px">
            <h2>PRODUCTION TRACKER</h2>
            <span class="count">@Model.Rows.Count jobs</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            @{ ViewBag.FilterAction = "Tracker"; }
            @await Html.PartialAsync("_FilterBar")
            <form method="get" asp-action="Tracker" style="display:inline-flex;gap:6px">
                <input type="hidden" name="filterCustomer" value="@ViewBag.FilterCustomer" />
                <input type="hidden" name="filterModel" value="@ViewBag.FilterModel" />
                <input class="search-input" name="search" placeholder="Search serial..." value="@Model.Search" />
            </form>
            <a class="btn btn-sm" href="@Url.Action("ExportCsv", "Home")">Export CSV</a>
            <button class="btn btn-sm" onclick="window.print()" style="white-space:nowrap">Print</button>
        </div>
    </div>

    <div class="machine-filters" id="machineFilters">
        <button class="mf-btn active" data-filter="all" onclick="setFilter(this,'all')">All</button>
        <div class="mf-sep"></div>
        @foreach (var (mod, count) in modules)
        {
            @for (int i = 1; i <= count; i++)
            {
                var key = $"{mod}#{i}";
                <button class="mf-btn" data-filter="@key" onclick="setFilter(this,'@key')">@key</button>
            }
            if (mod != "Shaper") { <div class="mf-sep"></div> }
        }
    </div>

    <div class="table-scroll">
        <table>
            <thead>
                <tr><th>Priority</th><th>Serial</th><th>Customer</th><th>Model</th><th>Drawing</th><th>Item Code</th><th>Description</th><th>Qty</th><th>Date</th><th>Processes</th><th>Status</th>@if(User.IsInRole("Manager")){<th>Actions</th>}</tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    var machineKeys = string.Join(" ", row.Job.ModuleEntries
                        .Where(e => !string.IsNullOrEmpty(e.MachineNumber))
                        .Select(e => $"{e.ModuleName}#{e.MachineNumber}"));
                    <tr class="@(row.IsComplete ? "row-green" : "")" data-machines="@machineKeys">
                        <td style="font-family:var(--font-mono);font-weight:700;text-align:center;font-size:.9rem;color:@(row.Job.Priority.HasValue ? "var(--white)" : "var(--text3)")">
                            @(row.Job.Priority.HasValue ? row.Job.Priority.ToString() : "—")
                        </td>
                        <td class="serial-cell">@row.Job.Serial</td>
                        <td>@row.Job.Customer</td>
                        <td>@row.Job.Model</td>
                        <td>@row.Job.Drawing</td>
                        <td style="font-family:var(--font-mono);font-size:.78rem">@(row.Job.ItemCode ?? "—")</td>
                        <td style="font-size:.78rem;color:var(--text2)">@(row.Job.DrawingDescription ?? "—")</td>
                        <td>@row.Job.Qty</td>
                        <td>@row.Job.InwardDate</td>
                        <td>
                            @if (row.Chips.Any())
                            {
                                @foreach (var chip in row.Chips)
                                {
                                    <span class="chip @(chip.IsDone ? "chip-green" : "chip-red")" style="margin-right:4px"
                                          title="@(chip.IsDone ? "Done" : $"Remaining: {chip.RemainingQty}")">
                                        @chip.Name
                                        @if (!chip.IsDone && chip.RemainingQty > 0)
                                        {
                                            <span style="font-size:.6rem;opacity:.8"> (@chip.RemainingQty)</span>
                                        }
                                    </span>
                                }
                            }
                            else
                            {
                                <span style="color:var(--text3)">—</span>
                            }
                        </td>
                        @{
                            var notStarted = !row.IsComplete && row.Chips.All(c => c.FinishedQty == 0);
                        }
                        <td style="font-family:var(--font-mono);font-size:.75rem;font-weight:600;color:@(row.IsComplete ? "var(--green)" : notStarted ? "var(--text3)" : "var(--white)")">
                            @(row.IsComplete ? "COMPLETE" : notStarted ? "Not Started" : "IN PROGRESS")
                        </td>
                        @if(User.IsInRole("Manager"))
                        {
                        <td style="white-space:nowrap">
                            @if (row.IsComplete)
                            {
                                <form method="post" asp-action="MoveToFinished" style="display:inline">
                                    <input type="hidden" name="id" value="@row.Job.Id" />
                                    <button type="submit" class="btn btn-sm" style="color:var(--green);border-color:var(--green-border);font-size:.6rem;margin-right:4px">✓ Finish</button>
                                </form>
                            }
                            <form method="post" asp-action="DeleteJob" style="display:inline">
                                <input type="hidden" name="id" value="@row.Job.Id" />
                                <button type="submit" onclick="return confirm('Delete job @row.Job.Serial permanently?')"
                                        class="btn btn-sm" style="color:var(--red);border-color:var(--red-border);font-size:.6rem">✕ Delete</button>
                            </form>
                        </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function setFilter(btn, filter) {
        document.querySelectorAll('.mf-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('tbody tr').forEach(row => {
            if (filter === 'all') {
                row.style.display = '';
            } else {
                var machines = row.dataset.machines || '';
                row.style.display = machines.split(' ').includes(filter) ? '' : 'none';
            }
        });
    }
</script>
