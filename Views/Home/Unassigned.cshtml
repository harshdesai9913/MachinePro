@model List<MachinePro.Models.Job>
@{ ViewData["Title"] = "UNASSIGNED TASKS"; }

@{
    var processOptions = new[] { "", "VMC", "Milling", "Lathe", "Shaper", "Other" };
}

<div class="table-wrap">
    <div class="table-header">
        <div style="display:flex;align-items:center;gap:12px">
            <h2>UNASSIGNED TASKS</h2>
            <span class="count">@Model.Count jobs</span>
        </div>
        <div>
            @{ ViewBag.FilterAction = "Unassigned"; }
            @await Html.PartialAsync("_FilterBar")
        </div>
    </div>
    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>Serial</th><th>Customer</th><th>Model</th><th>Drawing</th><th>Item Code</th><th>Description</th><th>Qty</th><th>Inward Date</th>
                    <th>Process 1</th><th>Process 2</th><th>Process 3</th><th>Process 4</th><th>Process 5</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="14" style="text-align:center;color:var(--text3);padding:24px;font-family:var(--font-mono);font-size:.8rem">No unassigned tasks — all jobs have processes assigned.</td></tr>
                }
                @foreach (var j in Model)
                {
                    <tr>
                        <td class="serial-cell">@j.Serial</td>
                        <td>@j.Customer</td>
                        <td>@j.Model</td>
                        <td style="font-family:var(--font-mono)">@j.Drawing</td>
                        <td style="font-family:var(--font-mono)">@(j.ItemCode ?? "—")</td>
                        <td style="color:var(--text2)">@(j.DrawingDescription ?? "—")</td>
                        <td>@j.Qty</td>
                        <td style="font-family:var(--font-mono)">@j.InwardDate</td>
                        @for (int pi = 0; pi < 5; pi++)
                        {
                            <td>
                                <select form="form-@j.Id" name="Process@(pi + 1)" style="padding:2px 4px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-size:.75rem">
                                    @foreach (var opt in processOptions)
                                    {
                                        <option value="@opt">@(string.IsNullOrEmpty(opt) ? "—" : opt)</option>
                                    }
                                </select>
                            </td>
                        }
                        <td>
                            <form id="form-@j.Id" method="post" asp-action="SavePlanner" style="display:inline">
                                <input type="hidden" name="JobId" value="@j.Id" />
                                <input type="hidden" name="Role" value="planner" />
                                <input type="hidden" name="ReturnTo" value="Unassigned" />
                                <button type="submit" class="btn btn-sm btn-primary" style="font-size:.7rem;padding:3px 10px;white-space:nowrap">Send to Planner →</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
