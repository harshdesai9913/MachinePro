@model HistoryViewModel
@{ ViewData["Title"] = "PLANNER HISTORY"; }

<div style="margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
    @{ ViewBag.FilterAction = "History"; }
    @await Html.PartialAsync("_FilterBar")
    <form method="get" asp-action="History" style="display:inline-flex;gap:6px">
        <input type="hidden" name="filterCustomer" value="@ViewBag.FilterCustomer" />
        <input type="hidden" name="filterModel" value="@ViewBag.FilterModel" />
        <input class="search-input" name="search" placeholder="Search serial..." value="@Model.Search" />
    </form>
    <form method="post" asp-action="ClearHistory" style="display:inline" onsubmit="return confirm('Clear all planner history? This cannot be undone.')">
        <button type="submit" class="btn btn-sm">Clear History</button>
    </form>
    <span style="font-size:.75rem;color:var(--text3);font-family:var(--font-mono)">@Model.Entries.Count entries</span>
</div>

<div class="table-wrap">
    <div class="table-header">
        <h2>PROCESS CHANGE LOG</h2>
        <span class="count">All planner modifications</span>
    </div>
    <div class="table-scroll">
        <table>
            <thead>
                <tr><th>Timestamp</th><th>Serial</th><th>Customer</th><th>Step</th><th>Previous</th><th>Changed To</th><th>Changed By</th></tr>
            </thead>
            <tbody>
                @if (!Model.Entries.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;color:var(--text3);padding:30px">
                            No changes recorded yet. Modify processes in the Planner to see history here.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var h in Model.Entries)
                    {
                        <tr>
                            <td style="font-family:var(--font-mono);font-size:.75rem;white-space:nowrap">@h.TimestampFormatted</td>
                            <td class="serial-cell">@h.Serial</td>
                            <td>@h.Customer</td>
                            <td><span style="font-family:var(--font-mono);font-size:.75rem">@h.Step</span></td>
                            <td>
                                @if (h.OldValue == "(empty)")
                                {
                                    <span style="color:var(--text3)">—</span>
                                }
                                else
                                {
                                    <span class="chip chip-red">@h.OldValue</span>
                                }
                            </td>
                            <td>
                                @if (h.NewValue == "(empty)")
                                {
                                    <span style="color:var(--text3)">—</span>
                                }
                                else
                                {
                                    <span class="chip chip-green">@h.NewValue</span>
                                }
                            </td>
                            <td style="font-size:.75rem;text-transform:uppercase;font-family:var(--font-mono);color:var(--text3)">@h.ChangedBy</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
