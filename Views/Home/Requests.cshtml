@model RequestsPageViewModel
@{ ViewData["Title"] = "SUBMIT ORDERS";
   var successMsg = TempData["Success"] as string;
   var errorMsg = TempData["Error"] as string;
}

@if (!string.IsNullOrEmpty(successMsg))
{
    <div style="background:var(--green-bg);border:1px solid var(--green-border);border-radius:var(--radius-lg);padding:14px 20px;margin-bottom:16px;color:var(--green);font-size:.85rem;font-weight:600;font-family:var(--font-mono)">✓ @successMsg</div>
}
@if (!string.IsNullOrEmpty(errorMsg))
{
    <div style="background:var(--red-bg);border:1px solid var(--red-border);border-radius:var(--radius-lg);padding:14px 20px;margin-bottom:16px;color:var(--red);font-size:.85rem;font-weight:600;font-family:var(--font-mono)">✕ @errorMsg</div>
}

<div class="table-wrap" style="padding:10px 16px;margin-bottom:12px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
    <span style="font-family:var(--font-mono);font-size:.7rem;color:var(--white);letter-spacing:1px;white-space:nowrap">IMPORT CSV</span>
    <form method="post" asp-action="ImportCsv" enctype="multipart/form-data" style="display:flex;align-items:center;gap:6px">
        <input type="file" name="csvFile" accept=".csv" required
               style="font-size:.7rem;font-family:var(--font-mono);color:var(--text2);background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:3px 6px" />
        <button type="submit" class="btn btn-primary btn-sm" style="font-size:.7rem;padding:3px 8px">Import</button>
    </form>
    <span style="font-size:.65rem;color:var(--text3);font-family:var(--font-mono)">Columns: Customer Name · Machine Model · DWG No. · Quantity · Item Code · Description</span>
</div>

<div class="table-wrap" style="padding:24px">
    <h2 style="font-family:var(--font-mono);font-size:.9rem;color:var(--white);margin-bottom:20px;letter-spacing:1px">NEW PART ORDER</h2>
    <form method="post" asp-action="SubmitRequest">
        <div class="form-grid">
            <div class="form-group">
                <label>Serial Number</label>
                <input value="@Model.NextSerial" readonly />
            </div>
            <div class="form-group">
                <label>Customer Name</label>
                <select name="Customer" required>
                    <option value="">— Select Customer —</option>
                    @foreach (var c in Model.Customers)
                    {
                        <option value="@c.CustomerName">@c.CustomerName</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Customer Model</label>
                <select name="Model" required>
                    <option value="">— Select Model —</option>
                    @foreach (var m in Model.Models)
                    {
                        <option value="@m.ModelName">@m.ModelName</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Drawing Number</label>
                <input name="Drawing" placeholder="e.g. DWG-2201" required />
            </div>
            <div class="form-group">
                <label>Item Code</label>
                <input name="ItemCode" placeholder="e.g. IC-4401" />
            </div>
            <div class="form-group">
                <label>Machine Build Number</label>
                <input name="MachineBuildNumber" placeholder="e.g. MB-001" />
            </div>
            <div class="form-group">
                <label>Drawing Description</label>
                <input name="DrawingDescription" placeholder="e.g. Engine block housing plate" />
            </div>
            <div class="form-group">
                <label>Quantity</label>
                <input name="Qty" type="number" min="1" placeholder="e.g. 12" required />
            </div>
            <div class="form-group">
                <label>Inward Date</label>
                <input value="@Model.Today" readonly />
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Submit Order</button>
    </form>
</div>

<div style="margin-top:24px">
    <div class="table-wrap">
        <div class="table-header">
            <h2>ALL ORDERS</h2>
            <span class="count">@Model.Jobs.Count entries</span>
        </div>
        <div class="table-scroll">
            <table>
                <thead>
                    <tr><th>Serial</th><th>Customer</th><th>Model</th><th>Drawing</th><th>Item Code</th><th>Machine Build #</th><th>Description</th><th>Qty</th><th>Date</th></tr>
                </thead>
                <tbody>
                    @foreach (var j in Model.Jobs)
                    {
                        <tr>
                            <td class="serial-cell">@j.Serial</td>
                            <td>@j.Customer</td>
                            <td>@j.Model</td>
                            <td>@j.Drawing</td>
                            <td style="font-family:var(--font-mono);font-size:.78rem">@(j.ItemCode ?? "—")</td>
                            <td style="font-family:var(--font-mono);font-size:.78rem;color:var(--orange)">@(j.MachineBuildNumber ?? "—")</td>
                            <td style="font-size:.78rem;color:var(--text2)">@(j.DrawingDescription ?? "—")</td>
                            <td>@j.Qty</td>
                            <td>@j.InwardDate</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
