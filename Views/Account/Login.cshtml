@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — MachinePro</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'IBM Plex Sans', sans-serif; background: #d0d0d0; color: #1a1a1a; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-box { background: #c0c0c0; border: 1px solid #999; border-radius: 10px; padding: 40px; width: 380px; max-width: 90%; }
        .login-brand { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 1.3rem; letter-spacing: 2px; color: #111; text-align: center; margin-bottom: 6px; }
        .login-sub { text-align: center; font-size: .75rem; color: #555; margin-bottom: 30px; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: .7rem; text-transform: uppercase; letter-spacing: 1.5px; color: #555; font-weight: 600; margin-bottom: 5px; }
        .form-group input { width: 100%; padding: 10px 12px; background: #b8b8b8; border: 1px solid #999; border-radius: 6px; color: #1a1a1a; font-family: 'IBM Plex Sans', sans-serif; font-size: .9rem; outline: none; }
        .form-group input:focus { border-color: #555; }
        .btn-login { width: 100%; padding: 12px; background: #111; color: #fff; border: 1px solid #111; border-radius: 6px; cursor: pointer; font-family: 'IBM Plex Sans', sans-serif; font-size: .9rem; font-weight: 600; letter-spacing: 1px; margin-top: 8px; }
        .btn-login:hover { background: #333; }
        .error-msg { background: rgba(229,57,53,.12); border: 1px solid rgba(229,57,53,.3); color: #e53935; padding: 10px 14px; border-radius: 6px; font-size: .82rem; margin-bottom: 16px; text-align: center; }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="login-brand">MACHINEPRO</div>
        <div class="login-sub">Production Tracker — Sign In</div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post" asp-action="Login" asp-controller="Account">
            @if (ViewBag.ReturnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            }
            <div class="form-group">
                <label>Username</label>
                <input name="username" placeholder="Enter your username" required autofocus />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input name="password" type="password" placeholder="Enter your password" required />
            </div>
            <button type="submit" class="btn-login">SIGN IN</button>
        </form>
    </div>
</body>
</html>
